<?xml version="1.0" encoding="UTF-8"?>


<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:id="candidatesDetailsPanel">

    <padding>
        <Insets top="15" right="10" bottom="10" left="10" />
    </padding>

    <Label fx:id="nameLabel" text="Select a candidate" styleClass="panel-title" />

    <Label fx:id="emailLabel" styleClass="detail-text" wrapText="true" maxWidth="Infinity" />

    <Label fx:id="phoneLabel" styleClass="detail-text" wrapText="true" maxWidth="Infinity" />

    <Label fx:id="addressLabel" styleClass="detail-text" wrapText="true" maxWidth="Infinity" />

    <Label fx:id="tagsLabel" styleClass="detail-text" wrapText="true" maxWidth="Infinity" />

    <Label fx:id="interviewedLabel" styleClass="detail-text" wrapText="true" maxWidth="Infinity" />

    <Label fx:id="remarkLabel" styleClass="detail-text" wrapText="true" maxWidth="Infinity" />

</VBox>
