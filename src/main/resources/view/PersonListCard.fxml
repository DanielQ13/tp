<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<HBox id="cardPane" fx:id="cardPane" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      spacing="12">
  <VBox spacing="8" HBox.hgrow="ALWAYS">
    <HBox spacing="10" alignment="CENTER_LEFT">

      <Label fx:id="id" styleClass="id-label"/>
      <Label fx:id="name" styleClass="name-label"/>

      <Region HBox.hgrow="ALWAYS"/>

      <Label fx:id="interviewed"/>
    </HBox>
      <FlowPane fx:id="tags" />

      <HBox spacing="20">
        <Label fx:id="phone" wrapText="true" />
        <Label fx:id="email" wrapText="true" maxWidth="Infinity" HBox.hgrow="ALWAYS" />
      </HBox>

      <Label fx:id="address" wrapText="true" maxWidth="Infinity" />

      <Label fx:id="remark" wrapText="true" maxWidth="Infinity" />

  </VBox>
</HBox>
